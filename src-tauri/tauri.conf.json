{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumi",
  "version": "0.1.0",
  "identifier": "app.lumi.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumi",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "overlay",
        "trafficLightPosition": { "x": 16, "y": 16 },
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/libmpv": "libmpv"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
